{
  "name": "@notils/ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    "./globals.css": "./src/styles/globals.css",
    "./components/*": "./src/components/*.tsx",
    "./lib/*": "./src/lib/*.ts",
    "./hooks/*": "./src/hooks/*.ts",
    "./theme/*": "./src/theme/*.tsx"
  },
  "scripts": {
    "ui:add": "shadcn add",
    "ui:diff": "shadcn add --diff",
    "ui:update": "shadcn@latest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@notils/config": "workspace:*",
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "shadcn": "^4.13.0",
    "tailwindcss": "^4.3.3",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.24.0",
    "next-themes": "^0.4.6",
    "tailwind-merge": "^3.6.0"
  }
}
