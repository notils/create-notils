{
  "name": "create-notils",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint:fix": "biome check . --write",
    "lint:unsafe": "biome check . --write --unsafe",
    "format": "biome format --write .",
    "typecheck": "turbo run typecheck",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@notils/config": "workspace:*",
    "husky": "^9.1.7",
    "turbo": "^2.10.5",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=18"
  },
  "devEngines": {
    "packageManager": {
      "name": "bun",
      "version": "1.3.14"
    }
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
